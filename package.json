{
  "name": "live-audit-cli",
  "version": "1.0.0",
  "description": "Herramienta CLI de auditoría en tiempo real para proyectos Node.js",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "live-audit": "./dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "watch": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "cli",
    "security",
    "audit",
    "dx"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "acorn": "^8.11.3",
    "acorn-walk": "^8.3.5",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "picocolors": "^1.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/pino": "^7.0.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  }
}
